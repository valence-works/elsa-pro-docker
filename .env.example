# Default shell admin configuration
CShells__Shells__0__Features__DefaultAdminUser__AdminUsername=admin
CShells__Shells__0__Features__DefaultAdminUser__AdminPassword=ChangeThisPassword123!

# ASP.NET Core Configuration
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080

# Database Configuration
CShells__Shells__0__Features__PostgreSqlWorkflowPersistence__ConnectionString=Host=postgres;Port=5432;Database=elsa;Username=elsa;Password=elsa
CShells__Shells__0__Features__PostgreSqlIdentityPersistence__ConnectionString=Host=postgres;Port=5432;Database=elsa;Username=elsa;Password=elsa

# Security Configuration (REQUIRED - Generate a secure random key)
CShells__Shells__0__Features__Identity__SigningKey=CHANGE-THIS-TO-A-SECURE-256-BIT-RANDOMLY-GENERATED-KEY

# CORS Configuration (set allowed origins using indexed keys; use "*" for development only)
Elsa__Cors__AllowedOrigins__0=http://localhost:8081
# Elsa__Cors__AllowedOrigins__1=https://yourdomain.com
